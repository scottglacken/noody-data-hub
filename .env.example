# ── NOODY DATA HUB — Environment Variables ──
# Copy this to .env.local for local dev, or add to Vercel Dashboard → Settings → Environment Variables

# App URL (your Vercel deployment URL)
APP_URL=https://your-app-name.vercel.app

# API Secret (generate any random string — used to protect your endpoints)
API_SECRET=change-me-to-something-random-and-long

# Vercel Cron Secret (auto-set by Vercel, or generate your own)
CRON_SECRET=your-cron-secret

# ── SHOPIFY ──
# From dev.shopify.com → Your App → Settings → Credentials
SHOPIFY_CLIENT_ID=your-client-id
SHOPIFY_CLIENT_SECRET=your-client-secret
SHOPIFY_STORE=noody-skincare.myshopify.com

# ── META ADS ──
# From Meta Business Manager → Business Settings → System Users → Generate Token
META_ACCESS_TOKEN=your-meta-system-user-token
META_AD_ACCOUNT_ID=your-ad-account-id-numbers-only

# ── GOOGLE ADS (future) ──
# GOOGLE_ADS_CUSTOMER_ID=
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_REFRESH_TOKEN=
